{
  "name": "@argos-wallet/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for Argos Wallet — self-hosted multi-tenant wallet infrastructure for Web3",
  "author": "Eric Mora <eric@2mes4.com>",
  "license": "BSL-1.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "homepage": "https://github.com/2mes4/argos-wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/2mes4/argos-wallet",
    "directory": "sdks/typescript/packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/2mes4/argos-wallet/issues"
  },
  "keywords": [
    "argos",
    "argos-wallet",
    "sdk",
    "wallet",
    "web3",
    "crypto",
    "blockchain",
    "ethereum",
    "polygon",
    "multi-tenant",
    "self-hosted"
  ],
  "engines": {
    "node": ">=18"
  }
}
