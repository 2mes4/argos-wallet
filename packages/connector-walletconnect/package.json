{
  "name": "@argos-wallet/connector-walletconnect",
  "version": "0.1.0",
  "description": "WalletConnect connector for Argos Wallet SDK — link any WalletConnect-compatible wallet (Rainbow, Trust, Ledger, etc.)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@argos-wallet/types": "*",
    "@walletconnect/ethereum-provider": "^2.16.0",
    "@walletconnect/modal": "^2.7.0"
  },
  "devDependencies": { "typescript": "^5.7.0" },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["wallet", "walletconnect", "connector", "rainbow", "trust-wallet", "ledger", "web3"]
}
