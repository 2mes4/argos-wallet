{
  "name": "@argos-wallet/react",
  "version": "0.1.0",
  "description": "React SDK for Argos Wallet — hooks and components for wallet management, transactions, and external wallet linking",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --config jest.config.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@argos-wallet/types": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "wallet",
    "react",
    "hooks",
    "web3",
    "crypto"
  ]
}
