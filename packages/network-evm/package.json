{
  "name": "@argos-wallet/network-evm",
  "version": "0.1.0",
  "description": "Generic EVM blockchain provider for Argos Wallet SDK (Ethereum, Polygon, Base, Arbitrum)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@argos-wallet/types": "*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2mes4/argos-wallet",
    "directory": "packages/network-evm"
  },
  "keywords": ["wallet", "evm", "ethereum", "polygon", "blockchain"]
}
