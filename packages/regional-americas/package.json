{
  "name": "@argos-wallet/regional-americas",
  "version": "0.1.0",
  "description": "Americas fiat gateway plugin for Argos Wallet SDK — ACH, SPEI, Stripe integration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@argos-wallet/types": "*"
  },
  "devDependencies": { "typescript": "^5.7.0" },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["wallet", "americas", "ach", "spei", "fiat"]
}
