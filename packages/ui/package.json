{
  "name": "@argos-wallet/ui",
  "version": "0.1.0",
  "description": "Embeddable Web Components for the Argos Wallet SDK — wallet cards, fiat bridge wizard, transaction history",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@argos-wallet/types": "*",
    "lit": "^3.2.0"
  },
  "devDependencies": { "typescript": "^5.7.0" },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/2mes4/argos-wallet",
    "directory": "packages/ui"
  },
  "keywords": ["wallet", "ui", "web-components", "lit", "embeddable"]
}
