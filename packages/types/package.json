{
  "name": "@argos-wallet/types",
  "version": "0.1.0",
  "description": "Shared TypeScript interfaces and types for the Argos Wallet SDK",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2mes4/argos-wallet",
    "directory": "packages/types"
  },
  "keywords": ["wallet", "types", "interfaces", "web3"]
}
